rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Only authenticated users can read/write
    match /vehicles/{vehicleId} {
      allow read, write: if request.auth != null;
    }

    // LP pages can be read publicly (for the public listing)
    match /vehicles/{vehicleId} {
      allow read: if resource.data.status == 'published' || resource.data.status == 'sold';
    }

    // Prompt settings — admin only
    match /settings/{doc} {
      allow read, write: if request.auth != null;
    }
  }
}
